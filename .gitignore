# ==============================
# 아이쑥크림(icecream) .gitignore
# monorepo: backend(FastAPI) + frontend(React/Vite)
# ==============================

# Common
.DS_Store
Thumbs.db
*.log
*.pid
*.seed
*.tmp
*.bak
*.swp
.idea/
.ide/
.vscode/
*.iml
.history/

# 환경변수 / 시크릿
.env
.env.*
!.env.example
*.pem
*.key
secrets/

# Python / FastAPI (backend)
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/
*.egg
.uv-cache

# 가상환경
.venv/
venv/
env/
ENV/

# 테스트 / 커버리지
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
.tox/
.nox/
.cache/

# 타입체크 / 린트
.mypy_cache/
.dmypy.json
.ruff_cache/
.pyre/

# 로컬 DB / 마이그레이션 임시
*.sqlite3
*.db
alembic/versions/*.pyc

# Node / React / Vite (frontend)
node_modules/
.pnp
.pnp.js
.yarn/
.yarn-integrity
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# 빌드 산출물
dist/
dist-ssr/
build/
.vite/
*.local

# 테스트 / 커버리지
coverage/
.nyc_output/

# 프레임워크 캐시
.eslintcache
.stylelintcache

# Docker
# compose override는 로컬 전용
docker-compose.override.yml

# Data / Artifacts
# 공공데이터 원본 캐시/덤프 (재생성 가능하므로 제외)
data/raw/
data/dump/
*.csv.gz

# OS & Editor
.tern-port
.netrwhist

# local
*.local.*
*.local
.local.*

# AI agent
.agent
.claude
