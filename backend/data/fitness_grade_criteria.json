{
  "meta": {
    "title": "국민체력100 유아기 체력인증 기준표",
    "ageGroup": "preschool",
    "ageRangeMonths": [48, 83],
    "source": "국민체육진흥공단 국민체력100 인증기준 (문화체육관광부 고시 제2025-0027호 기반)",
    "sourceUrl": "https://nfa.kspo.or.kr/reserve/0/selectMeasureGradeItemListByAgeSe.kspo",
    "note": "유아기 측정은 참고용으로 인증서가 발급되지 않으며 등급(씨앗·새싹·꽃·열매)만 판정한다. 성인·어르신식 조건부 혼합 로직은 없다.",
    "version": "2025",
    "gradeOrder": ["fruit", "flower", "sprout", "seed"],
    "comparisonRules": {
      "higher": "측정값 >= 기준값 이면 충족 (클수록 우수)",
      "lower": "측정값 <= 기준값 이면 충족 (시간 항목: 민첩성·협응력, 작을수록 우수)",
      "bmi": "측정값 < 기준값 이면 충족 (원문 부등호 '<' 반영, strict 미만)"
    },
    "judgeLogic": "gradeOrder 순서대로(fruit→flower→sprout) 각 등급의 requiredItems가 모두 충족되는 첫 등급을 부여. 어느 것도 충족 못하면 seed. 특정 등급의 requiredItems 중 미입력 값이 있으면 그 등급은 판정 불가(다음 등급으로), 단 seed는 항상 폴백 가능."
  },
  "items": {
    "cardio":       { "label": "심폐지구력", "measure": "10m 왕복오래달리기", "unit": "회",  "direction": "higher", "category": "health" },
    "grip":         { "label": "근력",     "measure": "상대악력",           "unit": "%",  "direction": "higher", "category": "health" },
    "muscularEnd":  { "label": "근지구력",  "measure": "윗몸말아올리기",       "unit": "회",  "direction": "higher", "category": "health" },
    "flexibility":  { "label": "유연성",    "measure": "앉아윗몸앞으로굽히기",  "unit": "cm", "direction": "higher", "category": "health" },
    "agility":      { "label": "민첩성",    "measure": "5m×4 왕복달리기",     "unit": "초",  "direction": "lower",  "category": "motor" },
    "power":        { "label": "순발력",    "measure": "제자리멀리뛰기",       "unit": "cm", "direction": "higher", "category": "motor" },
    "coordination": { "label": "협응력",    "measure": "3×3 버튼누르기",      "unit": "초",  "direction": "lower",  "category": "motor" },
    "bmi":          { "label": "신체조성",  "measure": "BMI",              "unit": "kg/㎡", "direction": "lower",  "category": "body" }
  },
  "gradeRules": {
    "fruit":  { "requiredItems": ["cardio", "grip", "muscularEnd", "flexibility", "agility", "power", "coordination"], "rule": "all" },
    "flower": { "requiredItems": ["cardio", "grip", "muscularEnd", "flexibility", "agility", "power", "coordination"], "rule": "all" },
    "sprout": { "requiredItems": ["cardio", "grip", "muscularEnd", "flexibility", "bmi"], "rule": "all" },
    "seed":   { "requiredItems": [], "rule": "fallback" }
  },
