APP_ENV=development
# Neon PostgreSQL connection string
DATABASE_URL=postgresql+psycopg://user:password@ep-example.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
# Local PostgreSQL fallback
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=icecream
# DB_USER=icecream
# DB_PASSWORD=change-me
# Docker Compose variable names, when used by the local database service
# POSTGRES_DB=icecream
# POSTGRES_USER=icecream
# POSTGRES_PASSWORD=change-me
JWT_SECRET_KEY=change-me-in-production
JWT_EXPIRE_MINUTES=60
ADMIN_EMAILS=
KSPO_API_KEY=
KSPO_CENTER_URL=
KSPO_ACTIVITY_URL=
